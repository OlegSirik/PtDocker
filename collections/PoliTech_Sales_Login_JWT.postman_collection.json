  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (password) -> save accessToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) {",
                  "    pm.collectionVariables.set('jwt', json.accessToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userLogin\": \"{{userLogin}}\",\n  \"password\": \"{{password}}\",\n  \"clientId\": \"{{clientId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/{{tenantCode}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "{{tenantCode}}",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Token (no password) -> save accessToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) {",
                  "    pm.collectionVariables.set('jwt', json.accessToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userLogin\": \"{{userLogin}}\",\n  \"clientId\": \"{{clientId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/{{tenantCode}}/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "{{tenantCode}}",
                "auth",
                "token"
              ]
            }
          },
          "response": []
        }
      ]
